async def upgrade_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    q = update.callback_query
    await q.answer()
    uid, data = update.effective_user.id, q.data
    if data == "upgrade_back":
        await upgrade_command(update, context)
        return
    if 'all_inventories' not in context.bot_data or uid not in context.bot_data['all_inventories']:
        context.bot_data['all_inventories'][uid] = {'coins': 0, 'artifacts': 0}
    inv = context.bot_data['all_inventories'][uid]
    art = inv.get('artifacts', 0)
    if 'upgrades' not in context.bot_data or uid not in context.bot_data['upgrades']:
        context.bot_data['upgrades'][uid] = {'mining_multiplier': 1.0, 'cooldown_reduction': 0, 'mining_level': 0, 'cooldown_level': 0}
    up = context.bot_data['upgrades'][uid]
    if data.startswith("upgrade_mining_"):
        cost = int(data.split("_")[2])
        if art < cost:
            await safe_edit_message(q, f"❌ Недостаточно артефактов! Нужно {cost}🔮, у вас {art}🔮\n\nВаши артефакты: {art}", parse_mode='Markdown', reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("⬅️ Назад", callback_data="upgrade_back")]]))
            return
        inv['artifacts'] -= cost
        up['mining_level'] += 1
        up['mining_multiplier'] *= 1.5
        await safe_edit_message(q, f"✅ Улучшение куплено за {cost}🔮 Артефактов!\n\n🔝 Производство увеличено в 1.5 раза!\nТекущий множитель: x{up['mining_multiplier']:.1f}\n\nВаши артефакты: {inv['artifacts']}", parse_mode='Markdown', reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("⬅️ Назад", callback_data="upgrade_back")]]))
    elif data.startswith("upgrade_cooldown_"):
        cost = int(data.split("_")[2])
        cur_cd = max(MIN_COOLDOWN, BASE_COOLDOWN - up['cooldown_reduction'] * 15)
        if cur_cd <= MIN_COOLDOWN:
            await safe_edit_message(q, f"❌ Кулдаун уже достиг минимального значения {MIN_COOLDOWN} секунд!\n\nВаши артефакты: {art}", parse_mode='Markdown', reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("⬅️ Назад", callback_data="upgrade_back")]]))
            return
        if art < cost:
            await safe_edit_message(q, f"❌ Недостаточно артефактов! Нужно {cost}🔮, у вас {art}🔮\n\nВаши артефакты: {art}", parse_mode='Markdown', reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("⬅️ Назад", callback_data="upgrade_back")]]))
            return
        inv['artifacts'] -= cost
        up['cooldown_level'] += 1
        up['cooldown_reduction'] += 1
        await safe_edit_message(q, f"✅ Улучшение куплено за {cost}🔮 Артефактов!\n\n⏱️ Кулдаун уменьшен на 15 секунд!\nТекущий кулдаун: {max(MIN_COOLDOWN, BASE_COOLDOWN - up['cooldown_reduction'] * 15)} сек\n\nВаши артефакты: {inv['artifacts']}", parse_mode='Markdown', reply_markup=InlineKeyboardMarkup([[InlineKeyboardButton("⬅️ Назад", callback_data="upgrade_back")]]))

