ARTIFACT_EXCHANGE = {"Графит": 100, "Метастекло": 50, "Кремний": 20, "Споровый стручок": 100, "Пластан": 5, "Кинетический сплав": 1, "Фазовая ткань": 2, "Пиротит": 20, "Взрывчатая смесь": 5}
COIN_EXCHANGE = {"Медь": 1, "Свинец": 1, "Песок": 1, "Уголь": 1, "Вода": 0.01, "Нефть": 0.05, "Криогенная жидкость": 0.1, "Титан": 2, "Торий": 5, "Графит": 4, "Метастекло": 4, "Кремний": 5, "Споровый стручок": 5, "Пластан": 25, "Кинетический сплав": 50, "Фазовая ткань": 100, "Пиротит": 10, "Взрывчатая смесь": 30}

async def buy_artifact(update: Update, context: ContextTypes.DEFAULT_TYPE, amt_str):
    uid = update.effective_user.id
    if 'all_inventories' not in context.bot_data or uid not in context.bot_data['all_inventories']:
        context.bot_data['all_inventories'][uid] = {'coins': 0, 'artifacts': 0}
    inv = context.bot_data['all_inventories'][uid]
    if amt_str == "all":
        amt = inv.get('coins', 0) // 1000
        if amt == 0:
            await update.message.reply_text("❌ Недостаточно монет!")
            return
    else:
        try:
            amt = int(amt_str)
            if amt <= 0:
                raise ValueError
        except ValueError:
            await update.message.reply_text("Выбери нужное количество артефактов\nПример: /buyartifact 1")
            return
    if inv.get('coins', 0) < amt * 1000:
        await update.message.reply_text("❌ Недостаточно монет!")
        return
    inv['coins'] -= amt * 1000
    inv['artifacts'] = inv.get('artifacts', 0) + amt
    await update.message.reply_text(f"✅ Вы купили 🔮 Артефакты в количестве {amt} шт!")

async def exchange_artifact(update: Update, context: ContextTypes.DEFAULT_TYPE, res, amt_str):
    uid = update.effective_user.id
    if res not in ARTIFACT_EXCHANGE:
        await update.message.reply_text("Этот ресурс нельзя обменять на артефакты!")
        return
    if 'all_inventories' not in context.bot_data or uid not in context.bot_data['all_inventories']:
        context.bot_data['all_inventories'][uid] = {'coins': 0, 'artifacts': 0}
    inv = context.bot_data['all_inventories'][uid]
    need = ARTIFACT_EXCHANGE[res]
    if res not in inv:
        await update.message.reply_text("❌ Недостаточно ресурсов!")
        return
    if amt_str == "all":
        amt = inv[res] // need
        if amt == 0:
            await update.message.reply_text("❌ Недостаточно ресурсов!")
            return
    else:
        try:
            amt = int(amt_str)
            if amt <= 0:
                raise ValueError
        except ValueError:
            await update.message.reply_text(f"Выбери нужное количество для обмена\nПример: /exchange{res}artifact 1")
            return
    if inv[res] < need * amt:
        await update.message.reply_text("❌ Недостаточно ресурсов!")
        return
    inv[res] -= need * amt
    if inv[res] == 0:
        del inv[res]
    inv['artifacts'] = inv.get('artifacts', 0) + amt
    await update.message.reply_text(f"✅ Вы обменяли {need * amt} {res} на {amt} 🔮 Артефактов!")

async def exchange_coins(update: Update, context: ContextTypes.DEFAULT_TYPE, res, amt_str):
    uid = update.effective_user.id
    if res not in COIN_EXCHANGE:
        await update.message.reply_text("Этот ресурс нельзя обменять на монеты!")
        return
    if 'all_inventories' not in context.bot_data or uid not in context.bot_data['all_inventories']:
        context.bot_data['all_inventories'][uid] = {'coins': 0, 'artifacts': 0}
    inv = context.bot_data['all_inventories'][uid]
    val = COIN_EXCHANGE[res]
    if res not in inv:
        await update.message.reply_text("❌ Недостаточно ресурсов!")
        return
    if amt_str == "all":
        amt = inv[res]
        if res in LIQUID_DISPLAY and res not in ITEM_RESOURCES:
            amt = int(amt)
        if amt == 0:
            await update.message.reply_text("❌ Недостаточно ресурсов!")
            return
    else:
        try:
            amt = int(amt_str)
            if amt <= 0:
                raise ValueError
        except ValueError:
            await update.message.reply_text(f"Выбери нужное количество для обмена\nПример: /exchange{res} 5")
            return
    if inv[res] < amt:
        await update.message.reply_text("❌ Недостаточно ресурсов!")
        return
    earned = int(amt * val) if val < 1 else amt * val
    inv[res] -= amt
    if inv[res] == 0:
        del inv[res]
    inv['coins'] = inv.get('coins', 0) + earned
    await update.message.reply_text(f"✅ Вы обменяли {amt} {res} на {earned} 🪙 Монет!")

async def craft_item(update: Update, context: ContextTypes.DEFAULT_TYPE, key, amt_str):
    uid = update.effective_user.id
    if key not in CRAFT_RECIPES:
        await update.message.reply_text("Неизвестный предмет для крафта!")
        return
    rec = CRAFT_RECIPES[key]
    if 'all_inventories' not in context.bot_data or uid not in context.bot_data['all_inventories']:
        context.bot_data['all_inventories'][uid] = {'coins': 0, 'artifacts': 0}
    inv = context.bot_data['all_inventories'][uid]
    if amt_str == "all":
        mx = float('inf')
        for r, n in rec['res'].items():
            if r in inv:
                mx = min(mx, inv[r] // n)
            else:
                mx = 0
                break
        if mx == 0:
            await update.message.reply_text("❌ Недостаточно ресурсов!")
            return
        amt = mx
    else:
        try:
            amt = int(amt_str)
            if amt <= 0:
                raise ValueError
        except ValueError:
            await update.message.reply_text(f"Выбери нужное количество ресурсов\nПример: /craft{key} 10")
            return
    for r, n in rec['res'].items():
        if inv.get(r, 0) < n * amt:
            await update.message.reply_text("❌ Недостаточно ресурсов!")
            return
    for r, n in rec['res'].items():
        inv[r] -= n * amt
        if inv[r] == 0:
            del inv[r]
    crafted = amt * rec['amount']
    inv[rec['name']] = inv.get(rec['name'], 0) + crafted
    unit = "мл" if rec['type'] == "liquid" else "шт"
    await update.message.reply_text(f"✅ Вы скрафтили {rec['name']} в количестве {crafted} {unit}!")

