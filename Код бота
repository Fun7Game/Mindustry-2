def get_random_resource():
    r = random.random()
    c = 0
    for res, ch in RESOURCES.items():
        c += ch
        if r <= c:
            return res
    return "Медь"

def get_mine_resource():
    r = random.random()
    c = 0
    for res, ch in MINE_RESOURCES.items():
        c += ch
        if r <= c:
            return res
    return "Медь"

def get_random_value(chances):
    r = random.random() * 100
    c = 0
    for ch, val in chances:
        c += ch
        if r <= c:
            return val
    return chances[-1][1]

def get_unique_items():
    return [i for i, ch in UNIQUE_ITEMS.items() if random.random() * 100 <= ch]

def get_resource_amount(res, ud=None):
    if res in ITEM_RESOURCES:
        if ud and 'mining_multiplier' in ud:
            return random.randint(int(BASE_MIN_ITEMS * ud['mining_multiplier']), int(BASE_MAX_ITEMS * ud['mining_multiplier']))
        return random.randint(BASE_MIN_ITEMS, BASE_MAX_ITEMS)
    elif res in LIQUID_RESOURCES:
        if ud and 'mining_multiplier' in ud:
            return random.randint(int(BASE_MIN_LIQUID * ud['mining_multiplier']), int(BASE_MAX_LIQUID * ud['mining_multiplier']))
        return random.randint(BASE_MIN_LIQUID, BASE_MAX_LIQUID)
    return 1

