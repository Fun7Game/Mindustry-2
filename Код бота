async def complete_drawing(update: Update, context: ContextTypes.DEFAULT_TYPE, uid):
    await asyncio.sleep(1)
    while True:
        if 'active_drawing' not in context.bot_data or uid not in context.bot_data['active_drawing']:
            return
        a = context.bot_data['active_drawing'][uid]
        if time.time() - a['start_time'] >= a['build_time'] * a['count']:
            if 'sector' not in context.bot_data:
                context.bot_data['sector'] = {}
            if uid not in context.bot_data['sector']:
                context.bot_data['sector'][uid] = {'core': 'Осколок', 'weapons': 0, 'turrets': {}, 'units': {}, 'wave': 1, 'last_attack_time': time.time(), 'last_wave_damage': 0, 'last_wave_composition': None}
            sd = context.bot_data['sector'][uid]
            sd['turrets'][a['name']] = sd['turrets'].get(a['name'], 0) + a['count']
            sd['weapons'] += a['defense'] * a['count']
            del context.bot_data['active_drawing'][uid]
            try:
                await update.effective_user.send_message(f"✅ Чертеж завершен! {a['name']} в количестве {a['count']} шт. добавлены на базу!")
            except:
                pass
            break
        await asyncio.sleep(5)

