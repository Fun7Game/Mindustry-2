def get_upgrade_cost(level):
    return 1 * (2 ** level) if level > 0 else 1

async def safe_edit_message(query, text=None, rm=None, pm=None):
    try:
        if text is not None:
            await query.edit_message_text(text, reply_markup=rm, parse_mode=pm)
        else:
            await query.edit_message_reply_markup(reply_markup=rm)
    except Exception as e:
        if "Message is not modified" in str(e) or "message is not modified" in str(e).lower():
            pass
        else:
            raise e

