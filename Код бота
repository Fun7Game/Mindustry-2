async def update_drone_resources(update: Update, context: ContextTypes.DEFAULT_TYPE):
    uid = update.effective_user.id
    if 'drones' not in context.bot_data:
        context.bot_data['drones'] = {}
    if uid not in context.bot_data['drones']:
        context.bot_data['drones'][uid] = {k: ({} if 'resources' in k else False if 'researched' in k else 0) for k in ['mono_researched','poly_researched','mega_researched','quad_researched','oct_researched','mono_count','poly_count','mega_count','quad_count','oct_count','mono_resources','poly_resources','mega_resources','quad_resources','oct_resources']}
        context.bot_data['drones'][uid]['last_update'] = time.time()
    dd = context.bot_data['drones'][uid]
    ct, lu = time.time(), dd.get('last_update', time.time())
    if 0 < ct - lu <= 86400 and 'all_inventories' in context.bot_data and uid in context.bot_data['all_inventories']:
        inv = context.bot_data['all_inventories'][uid]
        for dn, di in DRONES.items():
            res = dd.get(di['resources_key'], {})
            prod = di['production']
            for r, c in res.items():
                if c > 0:
                    amt = min(int((prod * c / 3600) * (ct - lu)), 1000000)
                    if amt > 0:
                        inv[r] = inv.get(r, 0) + amt
    dd['last_update'] = ct

