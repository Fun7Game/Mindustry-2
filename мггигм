async def upgrade_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    user_id = update.effective_user.id
    data = query.data
    inv = context.bot_data['all_inventories'][user_id]
    upgrades = context.bot_data['upgrades'][user_id]
    if data.startswith("upgrade_mining_"):
        cost = int(data.split("_")[2])
        if inv.get('artifacts', 0) < cost: await query.edit_message_text("❌ Недостаточно артефактов!"); return
        inv['artifacts'] -= cost
        upgrades['mining_level'] += 1
        upgrades['mining_multiplier'] *= 1.5
        await query.edit_message_text(f"✅ Производство увеличено! x{upgrades['mining_multiplier']:.1f}")
    elif data.startswith("upgrade_cooldown_"):
        cost = int(data.split("_")[2])
        if inv.get('artifacts', 0) < cost: await query.edit_message_text("❌ Недостаточно артефактов!"); return
        inv['artifacts'] -= cost
        upgrades['cooldown_level'] += 1
        upgrades['cooldown_reduction'] += 1
        await query.edit_message_text(f"✅ Кулдаун уменьшен! {max(MIN_COOLDOWN, BASE_COOLDOWN - upgrades['cooldown_reduction'] * 15)} сек")

