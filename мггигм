async def mine(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_id = update.effective_user.id
    await create_user_profile(user_id, context)
    upgrades = context.bot_data['upgrades'][user_id]
    current_cooldown = max(MIN_COOLDOWN, BASE_COOLDOWN - upgrades['cooldown_reduction'] * 15)
    current_time = time.time()
    last_use = context.bot_data['cooldowns'].get(user_id, 0)
    if current_time - last_use < current_cooldown:
        remaining = int(current_cooldown - (current_time - last_use))
        if remaining >= 3600:
            time_text = f"{remaining // 3600} ч {(remaining % 3600) // 60} мин {remaining % 60} сек"
        elif remaining >= 60:
            time_text = f"{remaining // 60} мин {remaining % 60} сек"
        else:
            time_text = f"{remaining} сек"
        await update.message.reply_text(f"❌ Ты уже недавно копал ресурсы!\n\nВозвращайся через {time_text}.")
        return
    context.bot_data['cooldowns'][user_id] = current_time
    resource = get_random_resource()
    amount = get_resource_amount(resource, upgrades)
    if resource == "Кинетический сплав":
        result_text = f"💥 *НЕВЕРОЯТНАЯ УДАЧА!*\n\nТы обнаружил заброшенную шахту и нашел контейнер с {amount} шт. Кинетическим сплавом! Мои поздравления!"
        if resource not in context.bot_data['all_inventories'][user_id]: context.bot_data['all_inventories'][user_id][resource] = 0
        context.bot_data['all_inventories'][user_id][resource] += amount
        await update.message.reply_text(result_text, parse_mode='Markdown')
        return
    mining_messages = ["⛏️ Вы ударили киркой по земле и добыли", "⛏️ Вы поставили бур и добыли", "⛏️ Исследуя местность, вы обнаружили и добыли"]
    selected_message = random.choice(mining_messages)
    unit = "шт" if resource in ITEM_RESOURCES else "мл"
    result_text = f"{selected_message} {resource} {amount} {unit}!"
    if resource not in context.bot_data['all_inventories'][user_id]: context.bot_data['all_inventories'][user_id][resource] = 0
    context.bot_data['all_inventories'][user_id][resource] += amount
    await update.message.reply_text(result_text)

