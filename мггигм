async def mine_info(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    user_id = update.effective_user.id
    mines = context.bot_data['mines'][user_id]
    drills = mines.get('drills', {})
    now = time.time()
    elapsed = min(now - mines.get('last_update', now), 86400)
    if elapsed > 0:
        prod = sum(DRILLS[n]['production'] * c for n, c in drills.items())
        if prod > 0:
            total = int(prod / 3600 * elapsed)
            stored = mines.get('stored', {})
            for _ in range(min(total, 10000)):
                r = get_mine_resource()
                stored[r] = stored.get(r, 0) + 1
            mines['stored'] = stored
    mines['last_update'] = now
    stored = mines.get('stored', {})
    text = f"🏔 *Шахта*\n\n"
    if drills: text += "\n".join(f"{DRILLS[n]['emoji']} {n}: {c} шт." for n, c in drills.items())
    else: text += "Нет буров\n"
    text += f"\n📦 Накоплено:\n" + "\n".join(f"{r}: {a} шт." for r, a in stored.items()) if stored else "\nНет накоплений"
    keyboard = [[InlineKeyboardButton("💰 Собрать", callback_data="mine_collect")], [InlineKeyboardButton("⬅️ Назад", callback_data="mine_back")]]
    await query.edit_message_text(text, parse_mode='Markdown', reply_markup=InlineKeyboardMarkup(keyboard))

async def mine_collect(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    user_id = update.effective_user.id
    mines = context.bot_data['mines'][user_id]
    stored = mines.get('stored', {})
    if not stored: await mine_info(update, context); return
    inv = context.bot_data['all_inventories'][user_id]
    for r, a in stored.items():
        inv[r] = inv.get(r, 0) + a
    mines['stored'] = {}
    await mine_info(update, context)

async def mine_back(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    await mineshaft_command(update, context)

