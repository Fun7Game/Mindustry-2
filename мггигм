# Функции чертежей
async def drawing_start(update: Update, context: ContextTypes.DEFAULT_TYPE, drawing_index):
    query = update.callback_query
    await query.answer()
    user_id = update.effective_user.id
    if user_id in context.bot_data['active_drawing']:
        await query.edit_message_text("❌ У вас уже есть активный чертеж!")
        return
    inv = context.bot_data['all_inventories'][user_id]
    if inv.get('artifacts', 0) < 5:
        await query.edit_message_text("❌ Нужно 5🔮!")
        return
    drawings = context.bot_data['drawings'][user_id]
    if drawing_index >= len(drawings): return
    drawing = drawings[drawing_index]
    inv['artifacts'] -= 5
    context.bot_data['active_drawing'][user_id] = {'index': drawing_index, 'name': drawing['name'], 'count': drawing['count'], 'defense': drawing['defense'], 'build_time': drawing['build_time'], 'start_time': time.time(), 'is_unit': drawing.get('is_unit', False)}
    asyncio.create_task(complete_drawing(update, context, user_id))
    await drawings_command(update, context)

async def complete_drawing(update: Update, context: ContextTypes.DEFAULT_TYPE, user_id):
    await asyncio.sleep(1)
    while user_id in context.bot_data['active_drawing']:
        active = context.bot_data['active_drawing'][user_id]
        if time.time() - active['start_time'] >= active['build_time'] * active['count']:
            sector = context.bot_data['sector'][user_id]
            if active['is_unit']: sector['units'][active['name']] = sector['units'].get(active['name'], 0) + active['count']
            else: sector['turrets'][active['name']] = sector['turrets'].get(active['name'], 0) + active['count']
            sector['weapons'] += active['defense'] * active['count']
            drawings = context.bot_data['drawings'][user_id]
            if 0 <= active['index'] < len(drawings): drawings.pop(active['index'])
            del context.bot_data['active_drawing'][user_id]
            try: await update.effective_user.send_message(f"✅ Чертеж завершен! {active['name']} ({active['count']} шт.) добавлен на базу!")
            except: pass
            break
        await asyncio.sleep(5)

async def drawing_cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    user_id = update.effective_user.id
    if user_id in context.bot_data['active_drawing']: del context.bot_data['active_drawing'][user_id]
    await drawings_command(update, context)

async def speedup_drawing(update: Update, context: ContextTypes.DEFAULT_TYPE, currency, seconds):
    query = update.callback_query
    await query.answer()
    user_id = update.effective_user.id
    if user_id not in context.bot_data['active_drawing']: return
    active = context.bot_data['active_drawing'][user_id]
    elapsed = time.time() - active['start_time']
    remaining = int((active['build_time'] * active['count']) - elapsed)
    if remaining <= 0: await complete_drawing(update, context, user_id); return
    if seconds > remaining: seconds = remaining
    inv = context.bot_data['all_inventories'][user_id]
    cost = seconds * 1000 if currency == "coins" else seconds
    if inv.get(currency, 0) < cost: await query.edit_message_text(f"❌ Недостаточно {currency}!"); return
    inv[currency] -= cost
    active['start_time'] = time.time() - (active['build_time'] * active['count'] - remaining + seconds)
    await drawings_command(update, context)

