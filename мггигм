async def exchange_artifact(update: Update, context: ContextTypes.DEFAULT_TYPE, resource_name, amount_str):
    user_id = update.effective_user.id
    await create_user_profile(user_id, context)
    try: amount = int(amount_str)
    except: await update.message.reply_text("Пример: /exchangesurgealloyartifact 1"); return
    inv = context.bot_data['all_inventories'][user_id]
    needed = ARTIFACT_EXCHANGE.get(resource_name, 0)
    if not needed: return
    if inv.get(resource_name, 0) < needed * amount: await update.message.reply_text("❌ Недостаточно ресурсов!"); return
    inv[resource_name] -= needed * amount
    if inv[resource_name] == 0: del inv[resource_name]
    inv['artifacts'] = inv.get('artifacts', 0) + amount
    await update.message.reply_text(f"✅ Обменяно {needed * amount} {resource_name} на {amount} 🔮")

async def exchange_coins(update: Update, context: ContextTypes.DEFAULT_TYPE, resource_name, amount_str):
    user_id = update.effective_user.id
    await create_user_profile(user_id, context)
    try: amount = int(amount_str)
    except: await update.message.reply_text("Пример: /exchangesilicon 5"); return
    inv = context.bot_data['all_inventories'][user_id]
    value = COIN_EXCHANGE.get(resource_name, 0)
    if not value: return
    if inv.get(resource_name, 0) < amount: await update.message.reply_text("❌ Недостаточно ресурсов!"); return
    inv[resource_name] -= amount
    if inv[resource_name] == 0: del inv[resource_name]
    coins_earned = int(amount * value) if value < 1 else amount * value
    inv['coins'] = inv.get('coins', 0) + coins_earned
    await update.message.reply_text(f"✅ Обменяно {amount} {resource_name} на {coins_earned} 🪙")

async def craft_item(update: Update, context: ContextTypes.DEFAULT_TYPE, item_key, amount_str):
    user_id = update.effective_user.id
    await create_user_profile(user_id, context)
    try: amount = int(amount_str)
    except: await update.message.reply_text(f"Пример: /craft{item_key} 10"); return
    recipe = CRAFT_RECIPES.get(item_key)
    if not recipe: return
    inv = context.bot_data['all_inventories'][user_id]
    for res, need in recipe['resources'].items():
        if inv.get(res, 0) < need * amount: await update.message.reply_text("❌ Недостаточно ресурсов!"); return
    for res, need in recipe['resources'].items():
        inv[res] -= need * amount
        if inv[res] == 0: del inv[res]
    crafted = amount * recipe['amount_per_craft']
    inv[recipe['name']] = inv.get(recipe['name'], 0) + crafted
    unit = "мл" if recipe['type'] == 'liquid' else "шт"
    await update.message.reply_text(f"✅ Скрафчено {crafted} {unit} {recipe['name']}!")

