    sector = context.bot_data['sector'][user_id]
    now = time.time()
    while now - sector.get('last_attack_time', now) >= WAVE_COOLDOWN:
        sector['last_attack_time'] = sector.get('last_attack_time', now) + WAVE_COOLDOWN
        wave = sector['wave']
        damage = get_wave_damage(wave)
